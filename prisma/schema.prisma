generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(CLIENT)
  firstName           String?
  lastName            String?
  phone               String?
  isApproved          Boolean              @default(false)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  locationId          String?
  addresses           Address[]
  favoriteRestaurants FavoriteRestaurant[]
  approvedMeals       Meal[]               @relation("MealApprover")
  createdMeals        Meal[]               @relation("MealCreator")
  orders              Order[]
  statusLogs          OrderStatusLog[]
  ownedRestaurants    Restaurant[]         @relation("RestaurantOwner")
  reviews             Review[]
  tagRequests         TagRequest[]
  workingAt           Location?            @relation("LocationWorker", fields: [locationId], references: [id])

  @@index([email])
  @@index([role])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  street     String
  city       String
  postalCode String
  country    String   @default("PL")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  label      String?
  latitude   Float?
  longitude  Float?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([userId])
}

model Review {
  id           String     @id @default(cuid())
  restaurantId String
  userId       String
  rating       Int
  content      String?
  isVisible    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([userId])
  @@index([rating])
}

model FavoriteRestaurant {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
}

model SubscriptionPlan {
  id               String               @id @default(cuid())
  name             String               @unique
  description      String?
  price            Decimal              @db.Decimal(10, 2)
  currency         String               @default("PLN")
  interval         SubscriptionInterval @default(MONTHLY)
  maxMeals         Int                  @default(50)
  maxLocations     Int                  @default(1)
  maxStaffAccounts Int                  @default(5)
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  subscriptions    Subscription[]
}

model Subscription {
  id                   String           @id @default(cuid())
  restaurantId         String
  planId               String
  startDate            DateTime         @default(now())
  endDate              DateTime?
  isActive             Boolean          @default(true)
  stripeSubscriptionId String?          @unique
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  plan                 SubscriptionPlan @relation(fields: [planId], references: [id])
  restaurant           Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([planId])
}

model Restaurant {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  logoUrl            String?
  coverImageUrl      String?
  bio                String?
  nip                String?
  ownerId            String
  status             RestaurantStatus     @default(PENDING)
  rejectionNote      String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  favoritedBy        FavoriteRestaurant[]
  locations          Location[]
  meals              Meal[]
  owner              User                 @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  reviews            Review[]
  subscriptions      Subscription[]
  visibilitySettings VisibilitySettings[]
  tags               RestaurantTag[]      @relation("RestaurantAmenities")
  cuisineTypes       CuisineType[]        @relation("RestaurantCuisines")

  @@index([ownerId])
  @@index([slug])
  @@index([status])
}

model Location {
  id             String            @id @default(cuid())
  restaurantId   String
  name           String
  address        String
  city           String
  postalCode     String            @default("")
  phone          String
  deliveryRadius Int               @default(5)
  deliveryFee    Decimal           @db.Decimal(10, 2)
  minOrderValue  Decimal           @db.Decimal(10, 2)
  openingHours   Json
  isAllDay       Boolean           @default(false)
  latitude       Float?
  longitude      Float?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  settings       LocationSettings?
  mealLocations  MealLocation[]
  orders         Order[]
  workers        User[]            @relation("LocationWorker")

  @@index([restaurantId])
  @@index([city])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meals       Meal[]

  @@index([slug])
}

model Meal {
  id              String             @id @default(cuid())
  restaurantId    String
  categoryId      String
  name            String
  slug            String
  description     String?
  imageUrl        String?
  basePrice       Decimal            @db.Decimal(10, 2)
  preparationTime Int
  weight          Int?
  calories        Int?
  protein         Decimal?           @db.Decimal(5, 2)
  carbs           Decimal?           @db.Decimal(5, 2)
  fat             Decimal?           @db.Decimal(5, 2)
  spiceLevel      Int                @default(0)
  isAvailable     Boolean            @default(true)
  isVegetarian    Boolean            @default(false)
  isVegan         Boolean            @default(false)
  isGlutenFree    Boolean            @default(false)
  approvalStatus  MealApprovalStatus @default(APPROVED)
  createdBy       String?
  createdByRole   Role?
  approvedBy      String?
  approvedAt      DateTime?
  rejectionNote   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  approver        User?              @relation("MealApprover", fields: [approvedBy], references: [id])
  category        Category           @relation(fields: [categoryId], references: [id])
  creator         User?              @relation("MealCreator", fields: [createdBy], references: [id])
  restaurant      Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  addons          MealAddon[]
  locations       MealLocation[]
  variants        MealVariant[]
  orderItems      OrderItem[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
}

model MealLocation {
  id          String   @id @default(cuid())
  mealId      String
  locationId  String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([mealId, locationId])
  @@index([mealId])
  @@index([locationId])
}

model MealVariant {
  id            String      @id @default(cuid())
  mealId        String
  name          String
  priceModifier Decimal     @db.Decimal(10, 2)
  isAvailable   Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  meal          Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@index([mealId])
}

model MealAddon {
  id          String           @id @default(cuid())
  mealId      String
  name        String
  price       Decimal          @db.Decimal(10, 2)
  isRequired  Boolean          @default(false)
  maxQuantity Int              @default(1)
  isAvailable Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  meal        Meal             @relation(fields: [mealId], references: [id], onDelete: Cascade)
  orderItems  OrderItemAddon[]

  @@index([mealId])
}

model Order {
  id                  String           @id @default(cuid())
  orderNumber         String           @unique
  userId              String?
  locationId          String
  addressId           String?
  type                OrderType        @default(DELIVERY)
  status              OrderStatus      @default(PENDING)
  paymentStatus       PaymentStatus    @default(PENDING)
  subtotal            Decimal          @db.Decimal(10, 2)
  deliveryFee         Decimal          @default(0) @db.Decimal(10, 2)
  discountPercent     Int              @default(0)
  totalPrice          Decimal          @db.Decimal(10, 2)
  notes               String?
  estimatedTime       Int?
  estimatedDeliveryAt DateTime?
  stripePaymentId     String?          @unique
  guestName           String?
  guestEmail          String?
  guestPhone          String?
  deliveryAddress     String?
  customerLat         Float?
  customerLng         Float?
  restaurantName      String?
  restaurantSlug      String?
  acceptedAt          DateTime?
  preparingAt         DateTime?
  readyAt             DateTime?
  inDeliveryAt        DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  address             Address?         @relation(fields: [addressId], references: [id])
  location            Location         @relation(fields: [locationId], references: [id])
  user                User?            @relation(fields: [userId], references: [id])
  items               OrderItem[]
  statusLogs          OrderStatusLog[]

  @@index([userId])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

model OrderItem {
  id         String           @id @default(cuid())
  orderId    String
  mealId     String
  variantId  String?
  quantity   Int              @default(1)
  basePrice  Decimal          @db.Decimal(10, 2)
  totalPrice Decimal          @db.Decimal(10, 2)
  note       String?
  mealName   String?
  createdAt  DateTime         @default(now())
  meal       Meal             @relation(fields: [mealId], references: [id])
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant    MealVariant?     @relation(fields: [variantId], references: [id])
  addons     OrderItemAddon[]

  @@index([orderId])
}

model OrderItemAddon {
  id          String    @id @default(cuid())
  orderItemId String
  addonId     String
  quantity    Int       @default(1)
  price       Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  addon       MealAddon @relation(fields: [addonId], references: [id])
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

model CuisineType {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[] @relation("RestaurantCuisines")

  @@index([slug])
}

model RestaurantTag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[] @relation("RestaurantAmenities")

  @@index([slug])
}

model DishTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model TagRequest {
  id          String           @id @default(cuid())
  name        String
  type        TagType
  requestedBy String
  status      TagRequestStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  requester   User             @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([type])
}

model OrderStatusLog {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  note       String?
  createdAt  DateTime     @default(now())
  user       User?        @relation(fields: [changedBy], references: [id])
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model LocationSettings {
  id               String   @id @default(cuid())
  locationId       String   @unique
  etaOffsetMinutes Int      @default(0)
  updatedBy        String?
  updatedAt        DateTime @updatedAt
  location         Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model VisibilitySettings {
  id           String     @id @default(cuid())
  restaurantId String
  role         Role
  panelKey     String
  isVisible    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, role, panelKey])
  @@index([restaurantId])
}

model Page {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  category        PageCategory
  content         String
  metaDescription String?
  isPublished     Boolean      @default(false)
  showInHeader    Boolean      @default(false)
  showInFooter    Boolean      @default(false)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isPublished])
}

enum Role {
  ADMIN
  OWNER
  MANAGER
  WORKER
  CLIENT
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderType {
  DELIVERY
  PICKUP
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionInterval {
  MONTHLY
  YEARLY
}

enum PageCategory {
  NAVIGATION
  INFORMATION
}

enum RestaurantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MealApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TagRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TagType {
  CUISINE
  AMENITY
  DISH
  CATEGORY
}
